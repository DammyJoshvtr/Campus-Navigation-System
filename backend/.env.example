# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/campus_nav

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=another-long-random-string-for-jwt

# ── Flask-Mail (use Gmail app password or any SMTP provider) ──────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
# Set Authorised redirect URI to your frontend URL
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── App settings ──────────────────────────────────────────────────────────────
# Domain suffix all student emails must end with
ALLOWED_EMAIL_DOMAIN=edu.ng
# OTP validity in minutes
OTP_EXPIRY_MINUTES=10
